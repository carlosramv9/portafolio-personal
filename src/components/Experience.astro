---
import type { Language } from '../data/portfolio';
import { experience } from '../data/portfolio';

interface Props {
  currentLang: Language;
  translations: any;
}

const { currentLang, translations } = Astro.props;
const t = translations[currentLang];
---

<section id="experience" class="py-20 bg-slate-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Title -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">{t.experience.title}</h2>
      <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
    </div>

    <!-- Timeline -->
    <div class="max-w-4xl mx-auto">
      {experience.map((exp, index) => (
        <div class="relative pl-8 pb-12 border-l-2 border-blue-600 last:pb-0">
          <!-- Timeline dot -->
          <div class="absolute left-[-9px] top-0 w-4 h-4 bg-blue-600 rounded-full border-4 border-slate-950"></div>

          <div class="bg-slate-800/50 rounded-lg p-6 border border-slate-700 hover:border-blue-500/50 transition-all duration-300">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
              <div>
                <h3 class="text-2xl font-bold text-white mb-1">{exp.position[currentLang]}</h3>
                <p class="text-blue-400 font-semibold">{exp.company[currentLang]}</p>
              </div>
              <span class="text-slate-400 text-sm mt-2 md:mt-0">{exp.period[currentLang]}</span>
            </div>

            <!-- Description -->
            <p class="text-slate-300 mb-4">{exp.description[currentLang]}</p>

            <!-- Achievements -->
            <ul class="space-y-2">
              {exp.achievements.map((achievement) => (
                <li class="flex items-start gap-2 text-slate-300">
                  <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span>{achievement[currentLang]}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
