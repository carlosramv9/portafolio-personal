---
import type { Language } from '../data/portfolio';

interface Props {
  project: any;
  currentLang: Language;
  translations: any;
}

const { project, currentLang, translations } = Astro.props;
const t = translations[currentLang];
---

<article class="group relative flex flex-col h-full bg-[#0a0f1a] rounded-2xl border border-slate-800/80 overflow-hidden transition-all duration-500 hover:border-slate-600 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/60">
  <!-- Image Container / Fallback Pattern -->
  <div class="relative w-full h-56 bg-slate-950 overflow-hidden border-b border-slate-800/50">
    {project.image ? (
      <>
        <img 
          src={project.image} 
          alt={project.name[currentLang]} 
          class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" 
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1a] via-[#0a0f1a]/40 to-transparent"></div>
      </>
    ) : (
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]">
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1a] via-[#0a0f1a]/80 to-transparent"></div>
        <div class="w-full h-full flex items-center justify-center opacity-30 group-hover:opacity-50 transition-opacity duration-500">
          <svg class="w-12 h-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
        </div>
      </div>
    )}
    
    {project.confidential && (
      <div class="absolute top-4 right-4 z-10">
        <span class="px-3 py-1 bg-amber-500/5 text-amber-500/80 text-[11px] uppercase tracking-wider font-mono rounded-md border border-amber-500/20 backdrop-blur-md shadow-sm">
          {t.projects.confidential}
        </span>
      </div>
    )}
  </div>

  <!-- Content Body -->
  <div class="p-7 flex flex-col flex-grow relative z-10 -mt-10">
    <div class="mb-5">
      <h3 class="text-2xl font-semibold text-slate-100 tracking-tight leading-snug group-hover:text-white transition-colors">
        {project.name[currentLang]}
      </h3>
      <p class="mt-2 text-sm font-medium text-slate-400">
        {project.role[currentLang]}
      </p>
    </div>

    <p class="text-slate-300/80 leading-relaxed text-[15px] mb-7 flex-grow">
      {project.summary[currentLang]}
    </p>

    <!-- Metrics -->
    {project.metrics && project.metrics.length > 0 && (
      <div class="mb-8 grid grid-cols-2 gap-3">
        {project.metrics.map((metric: any) => (
          <div class="bg-slate-900/60 rounded-xl p-3 border border-slate-800/60">
            <p class="text-[10px] uppercase tracking-wider text-slate-500 font-medium mb-1.5 truncate" title={metric.label[currentLang]}>{metric.label[currentLang]}</p>
            <p class="text-sm font-mono text-slate-200">{metric.value}</p>
          </div>
        ))}
      </div>
    )}

    <!-- Highlights -->
    {project.highlights && project.highlights.length > 0 && (
      <div class="mb-8">
        <ul class="space-y-3">
          {project.highlights.map((highlight: any) => (
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-slate-600 group-hover:bg-slate-400 transition-colors"></span>
              <span class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors leading-snug">{highlight[currentLang]}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Footer: Stack & Links -->
    <div class="mt-auto pt-6 border-t border-slate-800/80">
      <div class="flex flex-wrap gap-2 mb-5">
        {project.stack.map((tech: string) => (
          <span class="px-2.5 py-1 bg-slate-800/40 text-slate-300 font-mono text-[11px] rounded-md border border-slate-700/50 transition-colors group-hover:bg-slate-800/60 group-hover:border-slate-600/50 hover:text-white">
            {tech}
          </span>
        ))}
      </div>
      
      <div class="flex flex-wrap items-center gap-6">
        {project.link && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-slate-300 hover:text-white transition-colors text-sm font-medium group/link"
          >
            <svg class="w-4 h-4 text-slate-500 group-hover/link:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            {t.projects.viewMore}
          </a>
        )}
        
        {project.github && (
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-slate-300 hover:text-white transition-colors text-sm font-medium group/github"
          >
            <svg class="w-4 h-4 text-slate-500 group-hover/github:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            {t.projects.repo || 'GitHub'}
          </a>
        )}
      </div>
    </div>
  </div>
</article>
