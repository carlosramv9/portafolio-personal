---
import type { Language } from '../data/portfolio';

interface Props {
  project: any;
  currentLang: Language;
  translations: any;
}

const { project, currentLang, translations } = Astro.props;
const t = translations[currentLang];
---

<div class="bg-slate-800/50 rounded-lg border border-slate-700 overflow-hidden hover:border-blue-500/50 transition-all duration-300 hover:transform hover:scale-[1.02] flex flex-col h-full">
  <!-- Header -->
  <div class="p-6 border-b border-slate-700">
    <div class="flex items-start justify-between mb-3">
      <h3 class="text-xl font-bold text-white pr-4">{project.name[currentLang]}</h3>
      {project.confidential && (
        <span class="px-2 py-1 bg-yellow-500/10 text-yellow-400 text-xs rounded border border-yellow-500/30 whitespace-nowrap">
          {t.projects.confidential}
        </span>
      )}
    </div>
    <p class="text-slate-300 mb-4">{project.summary[currentLang]}</p>
    <p class="text-sm text-blue-400">{project.role[currentLang]}</p>
  </div>

  <!-- Content -->
  <div class="p-6 flex-grow">
    <!-- Stack -->
    <div class="mb-4">
      <h4 class="text-sm font-semibold text-slate-400 mb-2">{t.projects.stack}:</h4>
      <div class="flex flex-wrap gap-2">
        {project.stack.map((tech: string) => (
          <span class="px-3 py-1 bg-blue-500/10 text-blue-300 text-sm rounded-full border border-blue-500/30">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- Highlights -->
    <div class="mb-4">
      <h4 class="text-sm font-semibold text-slate-400 mb-2">{t.projects.highlights}:</h4>
      <ul class="space-y-2">
        {project.highlights.map((highlight: any) => (
          <li class="flex items-start gap-2 text-sm text-slate-300">
            <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>{highlight[currentLang]}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Metrics -->
    {project.metrics && project.metrics.length > 0 && (
      <div>
        <h4 class="text-sm font-semibold text-slate-400 mb-2">{t.projects.metrics}:</h4>
        <div class="grid grid-cols-1 gap-2">
          {project.metrics.map((metric: any) => (
            <div class="bg-slate-900/50 rounded p-2 border border-slate-700">
              <p class="text-xs text-slate-400">{metric.label[currentLang]}</p>
              <p class="text-sm font-semibold text-white">{metric.value}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Footer -->
  {project.link && (
    <div class="p-6 pt-0">
      <a
        href={project.link}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors text-sm"
      >
        {t.projects.viewMore}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  )}
</div>
