---
import type { Language } from '../data/portfolio';
import { projects } from '../data/portfolio';
import ProjectCard from './ProjectCard.astro';

interface Props {
  currentLang: Language;
  translations: any;
}

const { currentLang, translations } = Astro.props;
const t = translations[currentLang];
---

<section id="projects" class="py-20 bg-slate-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Title -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">{t.projects.title}</h2>
      <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
    </div>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-8">
      {projects.map((project) => (
        <ProjectCard project={project} currentLang={currentLang} translations={translations} />
      ))}
    </div>
  </div>
</section>
